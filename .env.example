# Frontend (Next.js) - local .env.example
# Copy to `.env.local` (recommended) or `.env` and restart dev server.

# Browser-side base URL for auth API calls.
# Recommended for HTTPS deployment: keep this as internal proxy path.
NEXT_PUBLIC_AUTH_API_URL=/api/auth-proxy

# Server-side target for the auth proxy route.
# In deployment, point this to your EC2 backend API URL.
BACKEND_AUTH_API_URL=http://18.233.113.253:8081/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL for the forum backend API used by server routes (/api/messages, /api/messages/*/reactions).
# You can specify multiple comma-separated URLs to use as fallbacks.
FORUM_BACKEND_URL=http://localhost:8080

# Additional backend services can be configured with the *_BACKEND_URL naming pattern.
# Example:
# TIMELINE_BACKEND_URL=http://localhost:8082

# Next.js dev server port (optional)
PORT=3000

# Node environment
NODE_ENV=development
