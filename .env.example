# Frontend (Next.js) - local .env.example
# Copy to `.env.local` (recommended) or `.env` and restart dev server.

# URL for the authentication API used by the frontend
NEXT_PUBLIC_AUTH_API_URL=http://localhost:8081/api

# Backend service URLs
FORUM_BACKEND_URL=http://localhost:8082
READING_BACKEND_URL=http://localhost:8083
CLAN_BACKEND_URL=http://localhost:8084
ACHIEVEMENT_BACKEND_URL=http://localhost:8085
USER_BACKEND_URL=http://localhost:8086

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Next.js dev server port (optional)
PORT=3000

# Node environment
NODE_ENV=development
