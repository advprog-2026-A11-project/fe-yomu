# Frontend (Next.js) - local .env.example
# Copy to `.env.local` (recommended) or `.env` and restart dev server.

# Browser-side base URL for auth API calls.
# Recommended for HTTPS deployment: keep this as internal proxy path.
NEXT_PUBLIC_AUTH_API_URL=/api/auth-proxy/api

# Server-side target for the auth proxy route.
# In deployment, point this to your EC2 backend API URL.
BACKEND_AUTH_API_URL=http://18.233.113.253:8081/api
