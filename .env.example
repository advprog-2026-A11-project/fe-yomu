# URL for the forum backend API used by server routes (/api/messages, /api/messages/*/reactions).
# You can specify multiple comma-separated URLs to use as fallbacks.
FORUM_BACKEND_URL=http://localhost:8080

# Additional backend services can be configured with the *_BACKEND_URL naming pattern.
# Example:
# TIMELINE_BACKEND_URL=http://localhost:8082

# Next.js dev server port (optional)
PORT=3000

# Node environment
NODE_ENV=development

